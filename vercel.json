{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "build" }
    },
    {
      "src": "backend/server.py",
      "use": "@vercel/python",
      "config": { "runtime": "python3.11" }
    }
  ],
  "rewrites": [
    {
      "source": "/_/backend/(.*)",
      "destination": "/backend/server.py"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/$1"
    }
  ]
}
